# Local / production secrets template. Copy to `.env` for dev (with `wrangler dev` / scripts).

# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

BETTER_AUTH_SECRET=your-secret-key-here-minimum-32-characters

# Public URL of this API (Better Auth baseURL). Local = wrangler dev origin; deployed = https://…workers.dev
BETTER_AUTH_URL=http://127.0.0.1:8787

# Google Gemini (payslip vision)
GEMINI_API_KEY=your-gemini-api-key

# Optional: return payslip analyze response from fixtures/payslip-analyze-dev-response.json (no Gemini; omit GEMINI_API_KEY ok)
# PAYSLIP_USE_ANALYZE_FIXTURE=true

# Optional: disable second Gemini pass for nekudot box refinement
# DISABLE_NEKUDOT_REFINE=true

# Optional: Google OAuth (omit both to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI is NOT read from env — Better Auth sends: {BETTER_AUTH_URL}/api/auth/callback/google
# In Google Cloud Console → OAuth client → Authorized redirect URIs, add that string EXACTLY (scheme/host/port).
# Examples (use what matches your BETTER_AUTH_URL; localhost vs 127.0.0.1 are different to Google):
#   http://localhost:3005/api/auth/callback/google
#   https://myapp.com/api/auth/callback/google

# Remote analyze script (scripts/analyze-payslip-remote.ts)
API_BASE_URL=http://127.0.0.1:8787
# Must be in backend CORS list + Better Auth trustedOrigins (default matches local Nuxt)
# PAYSLIP_SCRIPT_ORIGIN=http://localhost:3000
PAYSLIP_TEST_EMAIL=user@example.com
PAYSLIP_TEST_PASSWORD=your-password

# Email password authentication enabled
#EMAIL_PASSWORD_AUTH_ENABLED=false