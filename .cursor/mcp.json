{
  "mcpServers": {
    "Nuxt-UI MCP server": {
      "type": "http",
      "url": "https://ui.nuxt.com/mcp"
    },
    "Nuxt MCP Server": {
      "url": "https://nuxt.com/mcp"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "nodejs-api-docs": {
      "command": "npx",
      "args": ["-y", "mcp-server-nodejs-api-docs"]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {
        "MEMORY_PERSIST": true,
        "MEMORY_FILE_PATH": "${workspaceFolder}/.memory.jsonl"
      }
    }
  }
}