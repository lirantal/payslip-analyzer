# Public URL, used for OG Image when running nuxt generate
NUXT_PUBLIC_SITE_URL=

# --- API routing (pick one) ---
#
# A) Proxied (recommended with `pnpm dev` / PM2): browser calls same origin; Nitro proxies /api/* to the Worker.
#    Leave public API base empty and set BACKEND_URL to your Wrangler dev server.
NUXT_PUBLIC_API_BASE_URL=
BACKEND_URL=http://127.0.0.1:8787
#
# B) Direct to Worker (no proxy): set explicit Worker URL (cookies are on :8787, not the Nuxt port).
# NUXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8787
# BACKEND_URL=http://127.0.0.1:8787
#
# When using (A), set backend BETTER_AUTH_URL to the Nuxt origin the browser uses, e.g. http://localhost:3005
# (see backend README). Otherwise session cookies and OAuth callbacks can misalign.
