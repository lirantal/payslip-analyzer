{
  "name": "payslip-analyzer-monorepo",
  "private": true,
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "start": "pm2 start",
    "dev": "pm2 start",
    "reinstall": "rm -rf node_modules frontend/node_modules backend/node_modules && pnpm store prune && pnpm install",
    "dev:frontend": "pm2 start --only frontend",
    "dev:backend": "pm2 start --only backend",
    "stop": "pm2 stop all",
    "stop:frontend": "pm2 stop frontend",
    "stop:backend": "pm2 stop backend",
    "status": "pm2 list",
    "logs": "pm2 logs",
    "logs:frontend": "pm2 logs frontend",
    "logs:backend": "pm2 logs backend",
    "wrangler": "pnpm --filter backend exec wrangler",
    "drizzle-kit": "pnpm --filter backend exec drizzle-kit",
    "backend:tsx": "pnpm --filter backend exec tsx"
  },
  "pnpm": {
    "overrides": {
      "unimport": "4.1.1"
    },
    "onlyBuiltDependencies": [
      "protobufjs",
      "sharp",
      "workerd"
    ]
  },
  "devDependencies": {
    "pm2": "^6.0.14"
  }
}